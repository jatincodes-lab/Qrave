        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenantName\": \"Demo Cafe\",\n  \"tenantSlug\": \"{{tenantSlug}}\",\n  \"ownerEmail\": \"{{ownerEmail}}\",\n  \"ownerDisplayName\": \"Demo Owner\",\n  \"password\": \"{{ownerPassword}}\"\n}"
